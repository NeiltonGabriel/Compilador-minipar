// Recursao: fatorial e fibonacci
func number fatorial(var number n) {
    if (n <= 1) { return 1; }
    return n * fatorial(n - 1);
}
func number fib(var number n) {
    if (n < 2) { return n; }
    return fib(n - 1) + fib(n - 2);
}
print("fatorial(6):", fatorial(6));
print("fib(10):", fib(10));
print("aninhado:", fatorial(fib(4)));

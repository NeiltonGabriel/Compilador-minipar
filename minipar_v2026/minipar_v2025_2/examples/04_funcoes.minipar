// Funcoes: parametros, globais, chamadas aninhadas
var number base;
base = 10;
func number soma(var number x, var number y) {
    return x + y;
}
func number dobro(var number x) {
    return soma(x, x);
}
print("soma:", soma(3, 4));
print("dobro:", dobro(8));
print("usa global:", soma(base, dobro(5)));

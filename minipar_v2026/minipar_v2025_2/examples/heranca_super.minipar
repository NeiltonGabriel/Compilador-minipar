// examples/heranca_super.minipar
// Demonstra: herança, override e chamada a super.metodo()

class Animal {
    var string nome;

    func Animal(var string n) {
        nome = n;
    }

    func string descricao() {
        return nome;
    }
}

class Cachorro extends Animal {
    func Cachorro(var string n) {
        nome = n;
    }

    override func string descricao() {
        return super.descricao();
    }
}

var Cachorro c = new Cachorro("Rex");
print("Nome:", c.descricao());

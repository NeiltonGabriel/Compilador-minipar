// Aritmetica: +, -, *, /, %, comparacoes (em if, com paridade total)
var number a;
var number b;
a = 20;
b = 5;
print("soma:", a + b);
print("sub:", a - b);
print("mul:", a * b);
print("div:", a / b);
print("mod:", a % b);
if (a > b) { print("a maior que b"); }
if (a == b) { print("iguais"); } else { print("diferentes"); }
